# Notion 整合設定（可選，不設定仍可使用轉錄功能）
# 取得方式：https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 目標 Notion 頁面 ID（從頁面 URL 取得）
NOTION_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Obsidian 整合設定（可選）────────────────────────────────
# 設定您本地端 Obsidian Vault 中用來存放會議記錄的資料夾絕對路徑
OBSIDIAN_MEETING_PATH=/Users/您的使用者名稱/Documents/Obsidian/會議記錄

# ── LLM 標點後處理（二選一，設定一個即可）──────────────────────────
# 優先順序：Claude > OpenAI
# 費用：120 分鐘會議約 NT$0.03–0.05，不設定則跳過此步驟

# Claude Haiku（推薦，最準確，約 NT$0.03/場）
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT-4o-mini（約 NT$0.05/場）
# 取得：https://platform.openai.com/api-keys
OPENAI_API_KEY=

